generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model Branch {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  users     User[]
  sales     Sale[]
  purchases Purchase[]
  expenses  FixedExpense[]
  cortes    Corte[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  active    Boolean  @default(true)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
  cortes    Corte[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Product {
  id             String          @id @default(cuid())
  name           String
  sku            String          @unique
  price          Decimal         @db.Decimal(10, 2)
  costPrice      Decimal?        @db.Decimal(10, 2)
  stock          Int             @default(0)
  minStock       Int             @default(5)
  image          String?
  active         Boolean         @default(true)
  categoryId     String
  category       Category        @relation(fields: [categoryId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  saleItems      SaleItem[]
  stockMovements StockMovement[]
  purchaseItems  PurchaseItem[]

  @@index([categoryId])
  @@index([active])
}

model Sale {
  id             String     @id @default(cuid())
  total          Decimal    @db.Decimal(10, 2)
  note           String?
  syncedToSheets Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  employeeId     String
  employee       User       @relation(fields: [employeeId], references: [id])
  branchId       String?
  branch         Branch?    @relation(fields: [branchId], references: [id])
  items          SaleItem[]

  @@index([createdAt])
  @@index([employeeId])
}

model SaleItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Purchase {
  id        String         @id @default(cuid())
  date      DateTime       @default(now())
  note      String?
  createdAt DateTime       @default(now())
  branchId  String?
  branch    Branch?        @relation(fields: [branchId], references: [id])
  items     PurchaseItem[]

  @@index([date])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitCost   Decimal  @db.Decimal(10, 2)

  @@index([purchaseId])
  @@index([productId])
}

model FixedExpense {
  id           String   @id @default(cuid())
  name         String
  amount       Decimal  @db.Decimal(10, 2)
  categorySlug String?
  description  String?
  active       Boolean  @default(true)
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  createdAt    DateTime @default(now())
}

model Corte {
  id         String   @id @default(cuid())
  employeeId String
  employee   User     @relation(fields: [employeeId], references: [id])
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  price      Decimal  @db.Decimal(10, 2)
  ownerPct   Decimal  @db.Decimal(5, 2)
  note       String?
  createdAt  DateTime @default(now())

  @@index([employeeId])
  @@index([createdAt])
}

model StockMovement {
  id        String            @id @default(cuid())
  type      StockMovementType
  quantity  Int
  note      String?
  createdAt DateTime          @default(now())
  productId String
  product   Product           @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([createdAt])
}
